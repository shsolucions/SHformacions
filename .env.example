# WhatsApp contact number (international format without + or spaces)
# Example: 34600123456
VITE_WHATSAPP_NUMBER=34600000000

# App version
VITE_APP_VERSION=1.0.0

# Admin default PIN (change after first login)
VITE_DEFAULT_ADMIN_PIN=1234

# Google Drive OAuth (optional, for cloud backup)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Dropbox OAuth (optional, for cloud backup)
VITE_DROPBOX_APP_KEY=your_dropbox_app_key_here
